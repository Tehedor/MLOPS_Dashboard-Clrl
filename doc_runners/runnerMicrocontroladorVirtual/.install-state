# ESP32 Virtual Runner — Install State
# 'make snapshot' regenera la sección PRE_ con el estado actual del sistema.
# 'make uninstall' elimina solo lo marcado INST_=true con PRE_=false.
# No editar manualmente salvo que sepas lo que haces.

DISTRO=arch
CREATED_AT=2026-06-09

# Componentes pre-existentes antes de este Makefile (no se tocan en uninstall)
PRE_SOCAT=true
PRE_PYYAML=true
PRE_DOCKER=true
PRE_PYSERIAL=false
PRE_QEMU_ESP32=false

# Instalado por este Makefile (actualizado automáticamente por install)
INST_SOCAT=false
INST_PYSERIAL=false
INST_QEMU_ESP32=false
INST_QEMU_ESP32_PATH=/opt/qemu-esp32
