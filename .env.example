SUPABASE_PUBLISHABLE_KEY=XXXXXXX
SUPABASE_URL=XXXXXXX
SERVICE_ROLE_KEY=XXXXXXX
WEBHOOK_SECRET=XXXXXXX

SUPABASE_ACCESS_TOKEN=XXXXXXX


