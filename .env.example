DATABASE_URL=executions.db


# Nombres seleccionados de maenra dinamcia en función del nombre asignado en el campo github_token_env de cada pipeline en file config/pipelines.yaml
GITHUB_TOKEN_EDGE=XXXXXXX
GITHUB_TOKEN_EDGE_UNI=XXXXXXX
GITHUB_TOKEN_EDGE_TS=XXXXXXX

# Permisos necesarios Github Actions:
# * Despliega la sección **"Repository permissions"**.
# * Busca el permiso llamado **"Contents"** (Contenidos).
# * Cambia el desplegable a **"Access: Read and write"** (Lectura y escritura). *(Verás que al hacer esto, el permiso "Metadata" se pone automáticamente en Read, es normal).*

# Permisos para hacer pull, push y crear ramas:
# * Tokens Fine-grained: Mismo que arriba -> "Contents: Read and write".
# * Tokens Classic: Marcar el scope principal -> "repo".

# Actions       read-write
# Contents      read-write
# Metadata      read-only


# Dagshub creddenciales
DAGSHUB_USER=Tehedor
DAGSHUB_TOKEN=XXXXXXX


